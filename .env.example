# 🔷 IBM Watsonx Configuration (Required for all core text features)
WATSONX_APIKEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_SERVICE_URL=https://us-south.ml.cloud.ibm.com

# 🟠 Groq API Configuration (Optional: Needed for Whisper voice Speech-to-Text only)
GROQ_API_KEY=your_groq_api_key_here
